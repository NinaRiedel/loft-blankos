{
    "name": "qr-ticket-generator",
    "version": "1.0.0",
    "description": "Generate concert tickets with QR codes",
    "license": "UNLICENSED",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "typecheck": "tsgo -p tsconfig.app.json --noEmit && tsgo -p tsconfig.node.json --noEmit",
        "build": "tsgo -p tsconfig.app.json --noEmit && tsgo -p tsconfig.node.json --noEmit && vite build",
        "check": "biome check --log-kind=compact --diagnostic-level=error",
        "check:fix": "biome check --log-kind=compact --diagnostic-level=error --write",
        "test": "vitest",
        "test:run": "vitest run"
    },
    "keywords": [
        "qr-code",
        "tickets",
        "pdf"
    ],
    "dependencies": {
        "csv-writer": "^1.6.0",
        "jszip": "^3.10.1",
        "lucide-react": "^0.577.0",
        "papaparse": "^5.4.1",
        "pdf-lib": "^1.17.1",
        "pdfkit": "^0.18.0",
        "qrcode": "^1.5.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.8",
        "@types/node": "^24.12.0",
        "@types/papaparse": "^5.5.2",
        "@types/pdfkit": "^0.17.5",
        "@types/qrcode": "^1.5.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260322.1",
        "@vitejs/plugin-react": "^6.0.1",
        "tsx": "^4.7.0",
        "vite": "^8.0.1",
        "vitest": "^4.1.0"
    },
    "packageManager": "pnpm@10.12.1"
}
